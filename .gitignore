# ── Dataset (downloaded at runtime, too large for git) ────────────────────────
data/

# ── Trained model weights (binary, large) ─────────────────────────────────────
*.pth
*.pt

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── OS junk ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.user

# ── Logs and temp files ───────────────────────────────────────────────────────
*.log
*.tmp
*.bak